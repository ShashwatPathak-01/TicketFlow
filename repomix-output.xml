  authorize("Admin", "SupportAgent", "Employee"),
  getTickets,
);

router.get(
  "/:id",
  protect,
  authorize("Admin", "SupportAgent", "Employee"),
  getTicketById
);

router.put(
  "/:id",
  protect,
  authorize("Admin", "SupportAgent", "Employee"),
